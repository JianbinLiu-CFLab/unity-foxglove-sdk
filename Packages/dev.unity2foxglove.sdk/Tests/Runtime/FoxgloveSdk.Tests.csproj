<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>9.0</LangVersion>
    <Nullable>disable</Nullable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <BaseOutputPath>$(MSBuildProjectDirectory)\..\..\..\..\build\Tests\</BaseOutputPath>
    <BaseIntermediateOutputPath>$(BaseOutputPath)obj\</BaseIntermediateOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />

  </ItemGroup>
  <ItemGroup>
    <Compile Include="../../Runtime/Core/*.cs" />
    <Compile Include="../../Runtime/Protocol/*.cs" />
    <Compile Include="../../Runtime/Transport/*.cs" />
    <Compile Include="../../Runtime/Schemas/*.cs" />
    <Compile Include="Program.cs" />
    <Compile Include="SkeletonValidation.cs" />
    <Compile Include="Phase1Validation.cs" />
    <Compile Include="Phase2Validation.cs" />
    <Compile Include="Phase3Validation.cs" />
    <Compile Include="Phase4Validation.cs" />
    <Compile Include="Phase5Validation.cs" />
    <Compile Include="Phase6Validation.cs" />
    <Compile Include="Phase7Validation.cs" />
  </ItemGroup>
</Project>
